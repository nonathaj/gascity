# Agent drain commands moved to gc runtime drain/undrain/drain-check.
# Verify gc agent drain subcommands are no longer recognized
# (callers should use gc runtime drain, gc runtime undrain, gc runtime drain-check).

env GC_SESSION=fake
env GC_BEADS=file
env GC_DOLT=skip

# gc agent drain is removed — use gc runtime drain.
cd $WORK/test-city
! exec gc agent drain worker
stderr 'unknown subcommand "drain"'

# gc agent undrain is removed — use gc runtime undrain.
! exec gc agent undrain worker
stderr 'unknown subcommand "undrain"'

# gc agent drain-check is removed — use gc runtime drain-check.
! exec gc agent drain-check
stderr 'unknown subcommand "drain-check"'

-- test-city/.gc/.keep --
-- test-city/rigs/.keep --
-- test-city/city.toml --
[workspace]
name = "test-city"

[[agents]]
name = "worker"
start_command = "echo hello"
