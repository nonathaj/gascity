# gc agent attach is deprecated — verify it prints deprecation message.

env GC_SESSION=fake
env GC_BEADS=file
env GC_DOLT=skip

# gc agent attach prints deprecation regardless of config.
cd $WORK/cmd-city
! exec gc agent attach mayor
stderr 'removed, use "gc session attach" instead'

-- cmd-city/.gc/.keep --
-- cmd-city/rigs/.keep --
-- cmd-city/city.toml --
[workspace]
name = "cmd-city"

[[agents]]
name = "mayor"
start_command = "echo hello"
